; Engine configuration file.
; Crystalward — local co-op action tower defense (Godot 4)

config_version=5

[application]

config/name="Crystalward"
config/description="Local co-op action tower defense — protect the crystal from the soft dark."
run/main_scene="res://scenes/title.tscn"
config/features=PackedStringArray("4.3", "4.7", "Forward Plus")
config/icon="res://icon.svg"
config/macos_bundle_identifier="com.devth.crystalward"
config/version="0.1.0"

[autoload]

AppIdentity="*res://scripts/app_identity.gd"
GameState="*res://scripts/game_state.gd"
AssetPaths="*res://scripts/asset_paths.gd"
FX="*res://scripts/fx.gd"
PathNetwork="*res://scripts/path_network.gd"
Juice="*res://scripts/juice.gd"
Sfx="*res://scripts/audio_bus.gd"
VisualStyle="*res://scripts/visual_style.gd"
Music="*res://scripts/music.gd"
Campaign="*res://scripts/campaign.gd"
TowerTypes="*res://scripts/tower_types.gd"
EnemyKinds="*res://scripts/enemy_kinds.gd"
Powers="*res://scripts/powers.gd"
BurstPowerups="*res://scripts/burst_powerups.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

